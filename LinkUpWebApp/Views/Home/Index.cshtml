@model List<PostViewModel>
@{
    ViewData["Title"] = "My Posts";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>Mis Publicaciones</h2>
                <a asp-controller="Home" asp-action="Create" class="btn btn-primary">
                    Nueva Publicacion
                </a>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info">
                    No tienes publicaciones aun. Crea tu primera publicacion!
                </div>
            }
            else
            {
                @foreach (var post in Model)
                {
                    <div class="card mb-3">
                        <div class="card-header">
                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(post.UserProfilePicture))
                                {
                                    <img src="@post.UserProfilePicture" alt="@post.UserName"
                                         class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                }
                                <div>
                                    <strong>@post.UserFullName</strong>
                                    <small class="text-muted d-block">@post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                @if (post.IsOwner)
                                {
                                    <div class="ms-auto">
                                        <a asp-controller="Home" asp-action="Edit" asp-route-id="@post.Id"
                                           class="btn btn-sm btn-warning text-light">Editar</a> 
                                        <form asp-controller="Home" asp-action="Delete" asp-route-id="@post.Id"
                                              method="get" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger">Eliminar</button> 
                                        </form>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            <p>@post.Content</p>

                            @if (post.Type == PostType.Image && !string.IsNullOrEmpty(post.MediaPath))
                            {
                                <img src="@post.MediaPath" class="img-fluid mb-3" alt="Post image">
                            }
                            else if (post.Type == PostType.Video && !string.IsNullOrEmpty(post.YouTubeUrl))
                            {

                                var videoId = post.YouTubeUrl.Contains("v=")
                                ? post.YouTubeUrl.Split("v=")[1].Split("&")[0]
                                : post.YouTubeUrl.Split("/").Last();

                                <div class="ratio ratio-16x9 mb-3">
                                    <iframe src="https://www.youtube.com/embed/@videoId"
                                            allowfullscreen></iframe>
                                </div>
                            }


                            <div class="mb-3">
                                @if (post.UserReaction == ReactionType.Like)
                                {
                                    <span class="text-success me-2">
                                        <strong>Me gusta</strong> (@post.LikeCount)
                                    </span>

                                    <form asp-controller="Home" asp-action="ToggleReaction" method="post" class="d-inline">
                                        <input type="hidden" name="postId" value="@post.Id" />
                                        <input type="hidden" name="reactionType" value="dislike" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            No me gusta (@post.DislikeCount)
                                        </button>
                                    </form>
                                }
                                else if (post.UserReaction == ReactionType.Dislike)
                                {
                                    <form asp-controller="Home" asp-action="ToggleReaction" method="post" class="d-inline">
                                        <input type="hidden" name="postId" value="@post.Id" />
                                        <input type="hidden" name="reactionType" value="like" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            Me gusta (@post.LikeCount)
                                        </button>
                                    </form>

                                    <span class="text-danger ms-2">
                                        <strong>No me gusta</strong> (@post.DislikeCount)
                                    </span>
                                }
                                else
                                {
                                    <form asp-controller="Home" asp-action="ToggleReaction" method="post" class="d-inline">
                                        <input type="hidden" name="postId" value="@post.Id" />
                                        <input type="hidden" name="reactionType" value="like" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            Me gusta (@post.LikeCount)
                                        </button>
                                    </form>

                                    <form asp-controller="Home" asp-action="ToggleReaction" method="post" class="d-inline">
                                        <input type="hidden" name="postId" value="@post.Id" />
                                        <input type="hidden" name="reactionType" value="dislike" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            No me gusta (@post.DislikeCount)
                                        </button>
                                    </form>
                                }
                            </div>

                            <hr>
                            <h6>Comentarios (@post.Comments.Count)</h6>

                            @foreach (var comment in post.Comments)
                            {
                                @await Html.PartialAsync("_CommentPartial", comment)
                            }

                            <form asp-controller="Home" asp-action="AddComment" method="post" class="mt-3">
                                <input type="hidden" name="PostId" value="@post.Id" />
                                <div class="input-group">
                                    <input type="text" name="Content" class="form-control"
                                           placeholder="Escribe un comentario..." required />
                                    <button type="submit" class="btn btn-primary">Comentar</button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>