@model PendingFriendRequestViewModel

<div class="card mb-3 border-secondary">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <strong>@Model.SenderUserName</strong><br />
            <small>@Model.MutualFriendsCount amigos en comun</small><br />
            <small>Fecha: @Model.CreatedAt.ToString("dd/MM/yyyy")</small>
        </div>
        <div>
            <a asp-controller="FriendRequest" asp-action="Accept" asp-route-id="@Model.Id" class="btn btn-sm btn-success me-2">Aceptar</a>
            <a asp-controller="FriendRequest" asp-action="Reject" asp-route-id="@Model.Id" class="btn btn-sm btn-danger">Rechazar</a>
        </div>
    </div>
</div>