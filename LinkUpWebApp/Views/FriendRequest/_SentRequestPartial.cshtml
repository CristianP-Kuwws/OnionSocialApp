@model SentFriendRequestViewModel

@{
    var statusDisplay = Model.Status switch
    {
        FriendRequestStatus.Pending => "En espera de respuesta",
        FriendRequestStatus.Accepted => "Aceptada",
        FriendRequestStatus.Rejected => "Rechazada",
        _ => "Desconocido"
    };
}

<div class="card mb-3 border-secondary">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <strong>@Model.ReceiverUserName</strong><br />
            <small>@Model.MutualFriendsCount amigos en comun</small><br />
            <small>Fecha: @Model.CreatedAt.ToString("dd/MM/yyyy")</small><br />
            <small>Estado: @statusDisplay</small>
        </div>
        <div>
            <a asp-controller="FriendRequest" asp-action="Delete" asp-route-id="@Model.Id"
               class="btn btn-sm btn-danger">Eliminar</a>
        </div>
    </div>
</div>