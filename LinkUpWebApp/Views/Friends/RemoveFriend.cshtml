@model FriendViewModel
@{
    ViewData["Title"] = "Remove Friend";
}

<div class="col-12 col-md-6 offset-md-3 mt-4">
    <div class="card">
        <div class="card-header bg-danger text-light">
            <h5 class="text-center">Eliminar Amigo</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <strong>Esta seguro que desea eliminar a este amigo?</strong>
            </div>

            <div class="text-center mb-3">
                @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                {
                    <img src="@Model.ProfilePicture" alt="@Model.UserName"
                         class="rounded-circle mb-2" style="width: 80px; height: 80px; object-fit: cover;">
                }
                <h5>@Model.FullName</h5>
                <p class="text-muted">@@@Model.UserName</p>
            </div>

            <form asp-controller="Friends" asp-action="RemoveFriendConfirmed" method="post">
                <input type="hidden" name="friendId" value="@Model.UserId" />
                <button type="submit" class="btn btn-danger float-end">Eliminar</button>
                <a asp-controller="Friends" asp-action="Index" class="btn btn-outline-secondary float-end me-2">Cancelar</a>
            </form>
        </div>
    </div>
</div>