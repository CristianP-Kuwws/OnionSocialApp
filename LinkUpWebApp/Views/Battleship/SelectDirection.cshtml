@model LinkUpApp.Core.Application.ViewModels.Battleship.Ship.PositionShipViewModel

@{
    ViewData["Title"] = "Select Direction";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Seleccionar Direccion del Barco</h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-warning">@ViewBag.ErrorMessage</div>
                    }

                    <p>Celda seleccionada: <strong>Fila @ViewBag.StartRow, Columna @ViewBag.StartCol</strong></p>
                    <p>Tamano del barco: <strong>@ViewBag.ShipSize posiciones</strong></p>

                    <form asp-action="PositionShip" method="post">
                        <input type="hidden" name="GameId" value="@ViewBag.GameId" />
                        <input type="hidden" name="ShipType" value="@((int)ViewBag.ShipType)" />
                        <input type="hidden" name="StartRow" value="@ViewBag.StartRow" />
                        <input type="hidden" name="StartColumn" value="@ViewBag.StartCol" />

                        <div class="mb-3">
                            <label asp-for="Orientation" class="form-label">Direccion:</label>
                            <select asp-for="Orientation" class="form-select" required>
                                <option value="">Selecciona una direccion</option>
                                <option value="0">Arriba</option>
                                <option value="1">Abajo</option>
                                <option value="2">Izquierda</option>
                                <option value="3">Derecha</option>
                            </select>
                            <span asp-validation-for="Orientation" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Posicionar</button>
                            <a asp-action="SelectCell" asp-route-gameId="@ViewBag.GameId" asp-route-shipType="@((int)ViewBag.ShipType)" class="btn btn-outline-secondary">Volver Atras</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}