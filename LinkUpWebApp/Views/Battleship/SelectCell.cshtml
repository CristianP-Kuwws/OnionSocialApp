@model CellState[,]

@{
    ViewData["Title"] = "Select Cell";
}

<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Selecciona la Celda Inicial para tu Barco</h5>
        </div>
        <div class="card-body">
            <p class="text-muted">Barco de @ViewBag.ShipSize posiciones</p>

            <div class="alert alert-info">
                Blanco = Disponible | Gris = Ocupado
            </div>

            <div class="table-responsive">
                <table class="table table-bordered text-center" style="width: auto; margin: 0 auto;">
                    @for (int row = 0; row < 12; row++)
                    {
                        <tr>
                            @for (int col = 0; col < 12; col++)
                            {
                                var cellState = Model[row, col];
                                var isOccupied = cellState == LinkUpApp.Core.Domain.Common.Enum.Battleship.CellStates.CellState.Occupied;

                                <td style="width: 45px; height: 45px; padding: 0;" class="@(isOccupied ? "bg-secondary" : "")">
                                    @if (isOccupied)
                                    {
                                        <button type="button" class="btn btn-secondary w-100 h-100 d-flex align-items-center justify-content-center" disabled>
                                            <img src="/images/battleship/battleshipIcon.png" alt="Ship" style="width: 30px; height: 30px; object-fit: contain;" />
                                        </button>
                                    }
                                    else
                                    {
                                        <form asp-action="SelectCell" method="post" style="margin: 0;">
                                            <input type="hidden" name="gameId" value="@ViewBag.GameId" />
                                            <input type="hidden" name="shipType" value="@ViewBag.ShipSize" />
                                            <input type="hidden" name="selectedRow" value="@row" />
                                            <input type="hidden" name="selectedColumn" value="@col" />
                                            <button type="submit" class="btn btn-light w-100 h-100 d-flex align-items-center justify-content-center" style="border: 1px solid #dee2e6;">
                                                <img src="/images/battleship/battleshipIcon.png" alt="Ship" style="width: 30px; height: 30px; object-fit: contain;" />
                                            </button>
                                        </form>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </table>
            </div>

            <div class="mt-3">
                <a asp-action="SelectShip" asp-route-gameId="@ViewBag.GameId" class="btn btn-outline-secondary">Volver Atras</a>
            </div>
        </div>
    </div>
</div>